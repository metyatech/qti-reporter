<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item identifier="collision-choice" title="Choice Identifier Collision" adaptive="false" time-dependent="false" xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
  <qti-response-declaration identifier="RESPONSE" base-type="identifier" cardinality="single">
