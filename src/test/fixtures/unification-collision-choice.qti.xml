      <qti-value>CHOICE_A</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-item-body>
    <qti-p>First question.</qti-p>
    <qti-choice-interaction response-identifier="RESPONSE" max-choices="1">
      <qti-simple-choice identifier="CHOICE_A">Alpha</qti-simple-choice>
      <qti-simple-choice identifier="CHOICE_B">Beta</qti-simple-choice>
    </qti-choice-interaction>
    <qti-p>Second question sharing CHOICE_A as the identifier.</qti-p>
    <qti-choice-interaction response-identifier="COLLISION" max-choices="1">
      <qti-simple-choice identifier="CHOICE_A">Gamma</qti-simple-choice>
      <qti-simple-choice identifier="CHOICE_B">Delta</qti-simple-choice>
    </qti-choice-interaction>
    <qti-rubric-block view="scorer">
      <qti-p>[1] First picks Alpha</qti-p>
    </qti-rubric-block>
  </qti-item-body>
</qti-assessment-item>
