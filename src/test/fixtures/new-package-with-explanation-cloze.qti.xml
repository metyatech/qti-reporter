<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item identifier="new-cloze" title="New Cloze With Explanation" adaptive="false" time-dependent="false" xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
  <qti-response-declaration identifier="RESPONSE_1" base-type="string" cardinality="single">
    <qti-correct-response>
      <qti-value>first</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-response-declaration identifier="RESPONSE_2" base-type="string" cardinality="single">
    <qti-correct-response>
      <qti-value>second</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier" />
  <qti-item-body>
    <qti-p>Fill in the two ordered blanks.</qti-p>
    <qti-p>
      first=<qti-text-entry-interaction response-identifier="RESPONSE_1" />,
      second=<qti-text-entry-interaction response-identifier="RESPONSE_2" />
    </qti-p>
    <qti-rubric-block view="scorer">
      <qti-p>[1] Answers both blanks in order</qti-p>
    </qti-rubric-block>
  </qti-item-body>
  <qti-modal-feedback identifier="EXPLANATION" outcome-identifier="FEEDBACK" show-hide="show">
    <qti-content-body>
      <qti-p>Reasoning: <qti-code>x = 1</qti-code> captures the first blank then the second.</qti-p>
    </qti-content-body>
  </qti-modal-feedback>
</qti-assessment-item>
