<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item identifier="mixed-order" title="Mixed Order" adaptive="false" time-dependent="false" xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
  <qti-response-declaration identifier="RESPONSE_A" base-type="identifier" cardinality="single" />
  <qti-response-declaration identifier="RESPONSE_B" base-type="identifier" cardinality="single">
    <qti-correct-response>
      <qti-value>CHOICE_A</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-response-declaration identifier="TEXT_FILL" base-type="string" cardinality="single" />
  <qti-item-body>
    <qti-p>Select the first option.</qti-p>
    <qti-choice-interaction response-identifier="RESPONSE_A">
      <qti-simple-choice identifier="CHOICE_A">First Alpha</qti-simple-choice>
      <qti-simple-choice identifier="CHOICE_B">First Beta</qti-simple-choice>
    </qti-choice-interaction>
    <qti-p>Fill in the blank.</qti-p>
    <qti-text-entry-interaction response-identifier="TEXT_FILL" expected-length="20" />
    <qti-p>Select the third option.</qti-p>
    <qti-choice-interaction response-identifier="RESPONSE_B">
      <qti-simple-choice identifier="CHOICE_A">Third Gamma</qti-simple-choice>
      <qti-simple-choice identifier="CHOICE_B">Third Delta</qti-simple-choice>
    </qti-choice-interaction>
    <qti-rubric-block view="scorer">
      <qti-p>[1] Mixed order test</qti-p>
    </qti-rubric-block>
  </qti-item-body>
</qti-assessment-item>