<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item identifier="new-choice" title="New Choice With Explanation" adaptive="false" time-dependent="false" xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
  <qti-response-declaration identifier="RESPONSE" base-type="identifier" cardinality="single">
    <qti-correct-response>
      <qti-value>CHOICE_B</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier" />
  <qti-item-body>
    <qti-p>Choose the file that qti-reporter reads.</qti-p>
    <qti-choice-interaction response-identifier="RESPONSE" max-choices="1">
      <qti-simple-choice identifier="CHOICE_A">Markdown source</qti-simple-choice>
      <qti-simple-choice identifier="CHOICE_B">QTI package <qti-code>XML</qti-code></qti-simple-choice>
    </qti-choice-interaction>
    <qti-rubric-block view="scorer">
      <qti-p>[1] Selects the generated QTI package</qti-p>
    </qti-rubric-block>
  </qti-item-body>
  <qti-modal-feedback identifier="EXPLANATION" outcome-identifier="FEEDBACK" show-hide="show">
    <qti-content-body>
      <qti-p>Reasoning for the choice: the renderer ingests the QTI package produced by <qti-code>markdown-to-qti</qti-code> so the correct answer is <qti-code>x = 1</qti-code>.</qti-p>
      <qti-p>Code block follows.</qti-p>
      <qti-pre><qti-code class="language-ts">function pick() { return 'QTI package'; }</qti-code></qti-pre>
      <qti-p><qti-img src="images/sample.svg" alt="sample image for the explanation" /></qti-p>
    </qti-content-body>
  </qti-modal-feedback>
</qti-assessment-item>
